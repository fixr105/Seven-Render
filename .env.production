# Production build defaults — n8n is the data backend for loan application writes.
# VITE_API_BASE_URL: optional legacy Express proxy for auth/form-config (lms /api rewrite).
# VITE_N8N_LOAN_APPLICATIONS_URL: POST create/update (default: fixrrahul /webhook/loanapplications)
VITE_N8N_BASE_URL=https://fixrrahul.app.n8n.cloud
VITE_N8N_LOAN_APPLICATIONS_URL=https://fixrrahul.app.n8n.cloud/webhook/loanapplications
VITE_N8N_LOAN_APPLICATION_GET_URL=https://fixrrahul.app.n8n.cloud/webhook/loanapplication
