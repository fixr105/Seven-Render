# NBFC AI Tools (RAAD, PAGER, Query Drafter)
# Copy these to your .env (or merge with project root .env.example)

# Production n8n base URL for all NBFC tools (RAAD, PAGER)
# Default webhook paths: upload-bankstatement (RAAD), upload-pager (PAGER)
N8N_NBFC_TOOLS_BASE_URL=https://n8n-h9n3.srv1314414.hstgr.cloud

# Optional: override individual tool webhooks (full URL overrides base+path)
# N8N_RAAD_WEBHOOK_URL=
# N8N_PAGER_WEBHOOK_URL=

# Vercel Blob storage for report PDFs (RAAD, PAGER)
BLOB_READ_WRITE_TOKEN=
