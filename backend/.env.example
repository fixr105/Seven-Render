# NBFC AI Tools (RAAD, PAGER, Query Drafter)
# Copy these to your .env (or merge with project root .env.example)

# Required for RAAD, PAGER, Query Drafter - stores job status and report URLs
# Postgres: postgresql://user:pass@host:5432/dbname?schema=public
# Fly Postgres: fly postgres create then fly postgres attach
DATABASE_URL=

# Optional: full URL for create-folder webhook (defaults to N8N_BASE_URL/webhook/createfolder)
# N8N_CREATE_FOLDER_WEBHOOK_URL=https://fixrrahul.app.n8n.cloud/webhook/createfolder

# RAAD webhook (bank statement analysis)
N8N_RAAD_WEBHOOK_URL=https://fixrrahul.app.n8n.cloud/webhook/big-brain-bro-1

# RAAD fetch webhook (required for Report Viewer): POST {} = list all IDs; POST { loanApplicationId } = single report
# RAAD Report Viewer works without DATABASE_URL when this and N8N_RAAD_WEBHOOK_URL are set
N8N_RAAD_FETCH_WEBHOOK_URL=https://fixrrahul.app.n8n.cloud/webhook/get-raad

# Production n8n base URL for PAGER (or set N8N_PAGER_WEBHOOK_URL for full URL)
N8N_NBFC_TOOLS_BASE_URL=https://n8n-h9n3.srv1314414.hstgr.cloud

# Optional: override individual tool webhooks (full URL overrides base+path)
# N8N_RAAD_WEBHOOK_URL=
# N8N_PAGER_WEBHOOK_URL=

# Vercel Blob storage for report PDFs (RAAD, PAGER)
BLOB_READ_WRITE_TOKEN=
